# Maintainer: timirlan <timirlan@example.com>
pkgname=extip-rust
pkgver=$(grep '^version = ' Cargo.toml | sed 's/version = "\(.*\)"/\1/')
pkgrel=1
pkgdesc="External IP service with socket-based client"
arch=("x86_64")
license=("MIT")
depends=()
makedepends=("cargo" "rust")
provides=("extip")
conflicts=("extip-rust")
install=extip.install

prepare() {
    cd "$startdir"
    cargo fetch --locked
}

build() {
    cd "$startdir"
    cargo build --release --locked
}

package() {
    cd "$startdir"
    install -Dm755 "target/release/extip-rust" "$pkgdir/usr/bin/extip"
    install -Dm644 "extip.service" "$pkgdir/usr/lib/systemd/user/extip.service"
    install -Dm644 "extip.install" "$pkgdir/usr/share/doc/extip/extip.install"
}
