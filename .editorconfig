# http://editorconfig.org/#file-format-details
root = true

[*]
charset = utf-8
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = lf

[*.css]
indent_size = 2

[*.js]
indent_size = 2

[*.jsx]
indent_size = 2

[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2


[*.yaml]
indent_size = 2

[*.yml]
indent_size = 2

[*.toml]
indent_size = 2

[*.json]
indent_size = 2

[*.webmanifest]
indent_size = 2
